<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Athenus.App"
             RequestedThemeVariant="Light">

    <Application.Resources>
        <SolidColorBrush x:Key="MainBg" Color="#FAFAFA"/>
        <SolidColorBrush x:Key="Obsidian" Color="#1A1A1A"/>
        <SolidColorBrush x:Key="Gold" Color="#D4AF37"/>
        <SolidColorBrush x:Key="Platinum" Color="#B0B0B0"/>
        <BoxShadows x:Key="SoftDepth">0 10 30 0 #0A000000</BoxShadows>
        <Color x:Key="PlatinumBase">#E5E4E2</Color>
        <Color x:Key="PlatinumWhite">#F5F5F7</Color>
    
        <VisualBrush x:Key="GlitterBrush" 
                     TileMode="Tile" 
                     SourceRect="0,0,40,40" 
                     DestinationRect="0,0,40,40">
            <VisualBrush.Visual>
                <Canvas Width="40" Height="40" Background="Transparent">
                    <Ellipse Width="1" Height="1" Fill="#D4AF37" Opacity="0.3" Canvas.Left="5" Canvas.Top="10"/>
                    <Ellipse Width="1.5" Height="1.5" Fill="White" Opacity="0.8" Canvas.Left="25" Canvas.Top="5"/>
                    <Ellipse Width="1" Height="1" Fill="#B0B0B0" Opacity="0.4" Canvas.Left="15" Canvas.Top="30"/>
                    <Ellipse Width="2" Height="2" Fill="White" Opacity="0.6" Canvas.Left="35" Canvas.Top="25"/>
                </Canvas>
            </VisualBrush.Visual>
        </VisualBrush>
    
        <LinearGradientBrush x:Key="MetallicPlatinumBg" StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Offset="0" Color="#FFFFFF"/>
            <GradientStop Offset="0.5" Color="#F2F2F2"/>
            <GradientStop Offset="1" Color="#E5E4E2"/>
        </LinearGradientBrush>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <Style Selector="Button.GoldAction">
            <Setter Property="Background" Value="{StaticResource Gold}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.GoldAction:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#B8962E"/>
            <Setter Property="RenderTransform" Value="scale(1.02)"/>
        </Style>
    </Application.Styles>
</Application>
